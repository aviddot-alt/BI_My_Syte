---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';
---

<BaseLayout title="Courses" activePage="courses" description="Video courses on DAX, data modeling, and Power BI — coming soon.">

  <div class="container coming-soon">
    <p class="section-label" style="margin-bottom: 24px;">Courses</p>
    <h1>{site.coursesHeading}</h1>
    <p>{site.coursesDescription}</p>
    <div style="margin-top: 32px;">
      <a href="/contact" class="btn-primary">Get in touch</a>
    </div>
  </div>

</BaseLayout>
